# TORQ environment variables - example / template.
# Copy to `.env` and fill in real values. Never commit `.env`.

# --- LLM (DeepSeek-class reasoning model) ---
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# --- Vector DB (Qdrant) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Postgres (Supabase / Neon) ---
DATABASE_URL=

# --- MQTT (machine fault events) ---
MQTT_BROKER_URL=broker.hivemq.com
MQTT_PORT=1883
MQTT_TOPIC=torq/demo/faults

# --- Twilio (WhatsApp / SMS dispatch) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
# For scripts/test_whatsapp.py: a phone that has joined your Twilio sandbox.
TEST_WHATSAPP_TO=

# --- App ---
TORQ_ENV=dev
# ENABLE_FALLBACKS=true degrades MQTT/WhatsApp to in-app equivalents for demo safety.
ENABLE_FALLBACKS=true
